# Meraki API key — generate at https://dashboard.meraki.com -> Profile -> API access
MERAKI_API_KEY=your_meraki_api_key_here

# Zabbix API URL — base URL only, do NOT append /api_jsonrpc.php (added automatically)
ZABBIX_API_URL=https://your-zabbix-server/zabbix

# Zabbix API token — generate in Zabbix: Administration -> Users -> API tokens
ZABBIX_API_TOKEN=your_api_token_here

# Threshold percentage that triggers an alert (default: 90)
ALERT_THRESHOLD=90

# Minutes between scans when running in continuous mode (default: 30)
SCAN_INTERVAL=30
